rules_version = '2';

// RedRock 資料庫存取規則
// 本系統所有讀寫一律經後端 API（Firebase Admin SDK，會繞過本規則）。
// 前端不使用 Firebase client SDK、不直連 Firestore，因此對「客戶端直連」一律拒絕。
// 若日後真的需要前端直連，請針對特定 collection 撰寫最小權限規則，切勿放行 if true。
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
